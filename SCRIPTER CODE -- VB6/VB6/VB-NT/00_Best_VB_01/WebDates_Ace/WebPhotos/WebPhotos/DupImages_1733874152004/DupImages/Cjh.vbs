sub delhideimg(id) 
 if msgbox("Delete file ?",VBOKCancel,"Confirmation")=1 then
  Set filesys = CreateObject("Scripting.FileSystemObject")
  filename = document.getElementById(id).src
  filename = right(filename, len(filename) - 8)
  filename = htmlchars(filename)
  Set demofile = filesys.GetFile(filename)
  demofile.Delete
  document.getElementById(id).style.display="none"
 end if
end sub


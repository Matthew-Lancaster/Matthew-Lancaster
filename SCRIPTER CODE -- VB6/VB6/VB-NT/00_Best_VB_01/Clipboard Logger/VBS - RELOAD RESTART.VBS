Dim FSO
Set FSO = CreateObject("SCRIPTING.FILESYSTEMOBJECT")
On Error Resume Next

FC_1 = "D:\VB6\VB-NT\00_BEST_VB_01\CLIPBOARD LOGGER\CLIPBOARD LOGGER.EXE"



SET UAC = CREATEOBJECT("SHELL.APPLICATION")

FOR R1=1 TO 10
	ERR.CLEAR
	UAC.ShellExecute FC_1, "", "", "RUNAS", 1

	IF ERR.NUMBER > 0 THEN
		WSCRIPT.SLEEP 1000

	END IF
NEXT
IF ERR.NUMBER > 0 THEN
	MSGBOX "ERROR LAUNCH VB PROGRAM FROM UPDATE" + VBCRLF + FC_1 + VBCRLF + ERR.DESCRIPTION
END IF

WSCRIPT.QUIT 0

